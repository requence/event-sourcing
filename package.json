{
  "name": "@requence/event-sourcing",
  "version": "1.0.1",
  "description": "Event sourcing primitives — aggregate roots, projections, process managers, and event listeners",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./drizzle/postgres": {
      "bun": "./src/drizzle/postgres.ts",
      "types": "./dist/drizzle/postgres.d.ts",
      "import": "./dist/drizzle/postgres.js",
      "default": "./dist/drizzle/postgres.js"
    },
    "./drizzle": {
      "bun": "./src/drizzle/index.ts",
      "types": "./dist/drizzle/index.d.ts",
      "import": "./dist/drizzle/index.js",
      "default": "./dist/drizzle/index.js"
    },
    "./memory": {
      "bun": "./src/memory/index.ts",
      "types": "./dist/memory/index.d.ts",
      "import": "./dist/memory/index.js",
      "default": "./dist/memory/index.js"
    },
    "./redis": {
      "bun": "./src/redis/index.ts",
      "types": "./dist/redis/index.d.ts",
      "import": "./dist/redis/index.js",
      "default": "./dist/redis/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "test": "bun test",
    "check-types": "tsc --noEmit",
    "cs": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "async-mutex": "^0.5.0",
    "fast-equals": "^5.4.0",
    "superjson": "^2.2.6"
  },
  "peerDependencies": {
    "zod": "^4.3.6",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.9.3"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "drizzle-orm": "^0.45.1",
    "eslint": "^10.2.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "globals": "^17.5.0",
    "ioredis": "^5.10.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "zod": "^4.3.6"
  },
  "license": "MIT",
  "homepage": "https://event-sourcing.docs.requence.cloud",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/requence/event-sourcing.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
